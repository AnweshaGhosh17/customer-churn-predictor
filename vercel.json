{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/health",   "dest": "api/index.py" },
    { "src": "/docs",     "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/predict",   "dest": "frontend/pages/predict.html" },
    { "src": "/simulator", "dest": "frontend/pages/simulator.html" },
    { "src": "/dashboard", "dest": "frontend/pages/dashboard.html" },
    { "src": "/assets/(.*)", "dest": "frontend/assets/$1" },
    { "src": "/components/(.*)", "dest": "frontend/components/$1" },
    { "src": "/", "dest": "frontend/index.html" }
  ]
}
